{
    "name": "skunk1/chaincast",
    "description": "WordPress plugin to auto-publish posts to Hive/Steem (and future blockchains) via pluggable connectors.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.1",
        "ext-json": "*",
        "ext-openssl": "*",
        "ext-mbstring": "*",
        "ext-gmp": "*",
        "simplito/elliptic-php": "^1.0",
        "stephenhill/base58": "^1.1",
        "league/html-to-markdown": "^5.1",
        "woocommerce/action-scheduler": "^3.7"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Chaincast\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Chaincast\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "composer/installers": true
        },
        "optimize-autoloader": true
    }
}
