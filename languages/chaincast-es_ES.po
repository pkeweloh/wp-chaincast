#. Plugin Name of the plugin
msgid "Chaincast"
msgstr "Chaincast"

#. Description of the plugin
msgid "Auto-publish WordPress posts to Hive/Steem (and future chains) via pluggable connectors."
msgstr "Auto-publica entradas de WordPress en Hive/Steem (y futuras cadenas) mediante conectores enchufables."

msgid "Chaincast requires PHP %1$s or higher. Current version: %2$s."
msgstr "Chaincast requiere PHP %1$s o superior. Versión actual: %2$s."

msgid "Chaincast: Composer dependencies are missing. Run \"composer install\" in the plugin folder to enable signing and the queue."
msgstr "Chaincast: faltan las dependencias de Composer. Ejecuta \"composer install\" en la carpeta del plugin para habilitar la firma y la cola."

msgid "Account"
msgstr "Cuenta"

msgid "account"
msgstr "cuenta"

#. translators: %s: chain name, rendered as a link (e.g. Hive).
msgid "Also published on %s."
msgstr "También publicado en %s."

msgid "Add beneficiary"
msgstr "Añadir beneficiario"

msgid "Remove"
msgstr "Quitar"

msgid "Assigned"
msgstr "Asignado"

msgid "For you"
msgstr "Para ti"

msgid "No reward sharing: you keep 100%"
msgstr "Sin reparto: te quedas el 100%"

msgid "Hive Keychain not detected. Install the extension in your browser."
msgstr "No se detecta Hive Keychain. Instala la extensión en tu navegador."

msgid "Opening Keychain…"
msgstr "Abriendo Keychain…"

msgid "Published ✓"
msgstr "Publicado ✓"

msgid "Error"
msgstr "Error"

msgid "Permission denied."
msgstr "Permiso denegado."

msgid "Could not prepare the operation."
msgstr "No se pudo preparar la operación."

msgid "Missing permlink."
msgstr "Falta el permlink."

msgid "account:percentage, account:percentage"
msgstr "cuenta:porcentaje, cuenta:porcentaje"

msgid "%1$s: credentials valid (%2$s)"
msgstr "%1$s: credenciales correctas (%2$s)"

msgid "Enable a connector and save the settings before validating."
msgstr "Activa un conector y guarda los ajustes antes de validar."

msgid "The posting key was not saved: the CHAINCAST_KEY constant is missing in wp-config.php."
msgstr "No se guardó la posting key: falta la constante CHAINCAST_KEY en wp-config.php."

msgid "%s: the posting key is not a valid WIF; it was not saved."
msgstr "%s: la posting key no es una WIF válida; no se guardó."

msgid "Automatic mode disabled: define the CHAINCAST_KEY constant in wp-config.php to store the encrypted posting key."
msgstr "Modo automático deshabilitado: define la constante CHAINCAST_KEY en wp-config.php para poder guardar la posting key cifrada."

msgid "General"
msgstr "General"

msgid "Attribution footer"
msgstr "Pie de atribución"

msgid "Append a link to the original post"
msgstr "Añadir al final un enlace a la entrada original"

#. translators: %1$s and %2$s are the literal placeholders {site} and {url}.
msgid "Markdown. %1$s = site name, %2$s = link. Empty = default text."
msgstr "Markdown. %1$s = nombre del sitio, %2$s = enlace. Vacío = texto por defecto."

msgid "Reward sharing"
msgstr "Reparto de recompensas"

msgid "On Hive/Steem these are called \"beneficiaries\": accounts on THIS chain that receive a % of the post's author rewards. Use the right usernames for each chain."
msgstr "En Hive/Steem se llaman «beneficiaries»: cuentas DE ESTA cadena que reciben un % de las recompensas de autor del post. Usa los usuarios correctos de cada cadena."

msgid "No beneficiaries = you keep 100%. Applied only when first publishing to this chain."
msgstr "Sin beneficiarios = te quedas el 100%. Se aplica solo al publicar por primera vez en esta cadena."

msgid "Validate credentials"
msgstr "Validar credenciales"

msgid "Checks the stored posting keys against the accounts (without publishing anything)."
msgstr "Comprueba las posting keys guardadas contra las cuentas (sin publicar nada)."

msgid "Connector status"
msgstr "Estado de los conectores"

msgid "Enabled"
msgstr "Activado"

msgid "Publish to %s"
msgstr "Publicar en %s"

msgid "Automatic publishing"
msgstr "Publicación automática"

msgid "Publish to %s when the post is published in WordPress"
msgstr "Publicar en %s al publicar la entrada en WordPress"

msgid "If left unchecked, you decide when to publish using the button in the editor."
msgstr "Si lo dejas desmarcado, decides cuándo publicar con el botón del editor."

msgid "Account (author)"
msgstr "Cuenta (autor)"

msgid "Posting key"
msgstr "Posting key"

msgid "Limited-authority key (posting/voting only). Stored encrypted with AES-256-GCM. Do not use the Active or Owner key."
msgstr "Clave de autoridad limitada (solo publicar/votar). Se guarda cifrada con AES-256-GCM. No uses la Active ni la Owner."

msgid "Key saved & encrypted"
msgstr "Clave guardada y cifrada"

msgid "Replace key"
msgstr "Reemplazar clave"

msgid "Paste your private posting key"
msgstr "Pega tu clave privada de publicación"

msgid "Cancel"
msgstr "Cancelar"

msgid "Leave empty to keep the current key."
msgstr "Déjalo vacío para conservar la clave actual."

#. translators: 1: the literal {site} placeholder, 2: the literal {url} placeholder; keep the Markdown link format.
msgid "*Originally published at [%1$s](%2$s).*"
msgstr "*Publicado originalmente en [%1$s](%2$s).*"

msgid "Default category"
msgstr "Categoría por defecto"

msgid "Fallback community (parent_permlink) used when the post has no WordPress category. The first tag of the post on the chain."
msgstr "Comunidad (parent_permlink) de respaldo que se usa cuando la entrada no tiene categoría de WordPress. Es el primer tag del post en la cadena."

msgid "Category mapping"
msgstr "Mapeo de categorías"

msgid "Translate each WordPress category to its community (parent_permlink) on this chain. The post's primary category determines where it lands."
msgstr "Traduce cada categoría de WordPress a su comunidad (parent_permlink) en esta cadena. La categoría primaria de la entrada determina dónde aterriza."

msgid "There are no categories in WordPress yet."
msgstr "No hay categorías en WordPress todavía."

msgid "WordPress category"
msgstr "Categoría WordPress"

msgid "Tag / community on the chain"
msgstr "Tag / comunidad en la cadena"

msgid "Empty = the slug is used as-is."
msgstr "Vacío = se usa el slug tal cual."

msgid "No active connector (enable one and save the settings)."
msgstr "Ningún conector activo (actívalo y guarda los ajustes)."

msgid "Chain"
msgstr "Cadena"

msgid "Configured"
msgstr "Configurado"

msgid "Automatic mode"
msgstr "Modo automático"

msgid "No active connectors. Configure them in Settings → Chaincast."
msgstr "No hay conectores activos. Configúralos en Ajustes → Chaincast."

msgid "History"
msgstr "Historial"

msgid "Clear history"
msgstr "Borrar historial"

msgid "Published"
msgstr "Publicado"

msgid "Updated"
msgstr "Actualizado"

msgid "Keychain"
msgstr "Keychain"

msgid "view"
msgstr "ver"

msgid "Update on %s now"
msgstr "Actualizar en %s ahora"

msgid "Publish to %s now"
msgstr "Publicar en %s ahora"

#. translators: %s: chain name, e.g. Hive
msgid "Publish with %s Keychain"
msgstr "Publicar con %s Keychain"

msgid "Published to the chain: %s"
msgstr "Publicado en la cadena: %s"

msgid "Queued…"
msgstr "En cola…"

msgid "Not published"
msgstr "No publicado"
